BYBIT_API_KEY=your_testnet_api_key_here
BYBIT_API_SECRET=your_testnet_api_secret_here

# By default бот настроен на работу с Testnet.
# Для реальной торговли меняй только флаг testnet в config.py,
# а НЕ ключи.

TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Если запущена оптимизация (optimize.py), файл логов лучше отключить,
# чтобы не ловить проблемы блокировки файла на Windows.
# В optimize.py это выставляется автоматически, но можно выключить и вручную.
BOT_DISABLE_FILE_LOGGING=0

